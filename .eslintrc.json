{
    "root": true,
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "extends": [
        "react-app"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "ignorePatterns": [
        "agnus-back/**",
        "agnus-front/node_modules/**",
        "agnus-front/build/**",
        "agnus-front/coverage/**"
    ]
}